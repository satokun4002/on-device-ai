# On-Device AI Framework Configuration

# Model paths (adjust based on your setup)
TEXT_GEN_MODEL_PATH=./models/distilgpt2.onnx
IMAGE_MODEL_PATH=./models/mobilenetv3.onnx
CODE_GEN_MODEL_PATH=./models/starcoder-small.onnx

# ONNX Runtime settings
ONNX_EXECUTION_PROVIDER=cpu
ONNX_LOG_LEVEL=warning

# Inference settings
MAX_TEXT_LENGTH=512
IMAGE_INPUT_SIZE=224
CODE_MAX_LENGTH=256

# API settings (for Node.js server)
API_PORT=3000
API_HOST=localhost

# Model download settings
MODELS_CACHE_DIR=./models
ENABLE_MODEL_CACHE=true
